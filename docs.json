{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Cuz Help Center",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "https://source.starrysky.ggff.net/ame-assets/cuz-icon.svg",
  "navigation": {
    "groups": [
      {
        "group": "社区",
        "pages": [
          "group/index",
          "group/group-rules"
        ]
      },
      {
        "group": "Cuz AI",
        "pages": [
          "cuz-ai/cuz-ai-welcome",
          "cuz-ai/cuz-ai-login",
          "cuz-ai/cuz-ai-tos",
          "cuz-ai/api"
        ]
      },
      {
        "group": "其他",
        "pages": [
          "others/channels-notebook"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Cuz AI API",
          "icon": "rectangle-api",
          "href": "https://ai.cuz-lab.space"
        },
        {
          "anchor": "Uptime",
          "icon": "internet-explorer",
          "href": "https://up.c0ffee.space/status"
        }
      ]
    }
  },
  "redirects": [
    { "source": "/group-rules", "destination": "/group/group-rules" },
    { "source": "/cuz-ai-welcome", "destination": "/cuz-ai/cuz-ai-welcome" },
    { "source": "/cuz-ai-login", "destination": "/cuz-ai/cuz-ai-login" },
    { "source": "/cuz-ai-tos", "destination": "/cuz-ai/cuz-ai-tos" }
  ],
  "logo": {
    "light": "https://source.starrysky.ggff.net/ame-assets/Help-Center.svg",
    "dark": "https://source.starrysky.ggff.net/ame-assets/Help-Center.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@amethyst.ltd"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Cuz AI",
      "href": "https://ai.cuz-lab.space"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/Starry_SkyWorld",
      "github": "https://github.com/CuzTeam"
    }
  }
}
